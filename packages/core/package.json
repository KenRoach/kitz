{
  "name": "@kitz/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/types/index.js",
    "./utils": "./dist/utils/index.js",
    "./clients": "./dist/clients/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "postinstall": "test -f ../../prisma/schema.prisma && prisma generate || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^6.3.0",
    "dotenv": "^16.4.0",
    "pino": "^9.6.0",
    "prisma": "6.19.2",
    "zod": "^3.24.0"
  },
  "prisma": {
    "schema": "../../prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
