# ============================================================================
# KitZ Railway Environment Variables
# Copy this file and set values in Railway dashboard per service.
# DO NOT commit actual secrets to git.
# ============================================================================

# ── Shared (set as Railway project-level variables) ──────────────────────────

# Supabase — same project for all services
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres.xxxx:password@xxxx.supabase.co:6543/postgres

# AI providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...                  # optional
GEMINI_API_KEY=...                     # optional
DEFAULT_LLM_PROVIDER=claude

# ── kitz-gateway (port 8787) ────────────────────────────────────────────────

PORT=8787
HOST=0.0.0.0
AUTH_ENABLED=true
NODE_ENV=production
LOG_LEVEL=info

# Error tracking (Sentry)
SENTRY_DSN=                            # optional — get from sentry.io project settings

# Partner portal
PARTNER_TOKEN_SECRET=                  # REQUIRED — generate with: openssl rand -hex 32

# CORS — comma-separated public URLs for KitZ web and RenewFlow
# Replace with your actual Railway public URLs (or custom domains)
CORS_ORIGIN=https://kitz-web-production.up.railway.app,https://renewflo-production.up.railway.app,http://localhost:3000,http://localhost:4000

# App URL (used in emails, password reset links)
APP_URL=https://renewflo-production.up.railway.app

# SMTP (all required if SMTP_HOST is set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Resend (alternative to SMTP)
RESEND_API_KEY=
EMAIL_FROM=RenewFlow <noreply@renewflow.io>

# WhatsApp
WHATSAPP_SESSION_DIR=./wa_sessions

# ElevenLabs (voice, optional)
ELEVENLABS_API_KEY=

# Static file serving (set if gateway serves frontend SPA directly)
STATIC_DIR=

# ── factory-api (port 3000) ─────────────────────────────────────────────────

# DATABASE_URL — shared from project
# PORT=3000

# ── agent-runtime (port 3001) ───────────────────────────────────────────────

# DATABASE_URL, ANTHROPIC_API_KEY — shared from project
# PORT=3001

# ── pipeline-runner (port 3002) ──────────────────────────────────────────────

# DATABASE_URL — shared from project
# PORT=3002
REDIS_URL=redis://default:xxx@xxx.railway.internal:6379

# ── contact-engine (port 3003) ──────────────────────────────────────────────

# DATABASE_URL — shared from project
# PORT=3003

# ── channel-router (port 3004) ──────────────────────────────────────────────

# DATABASE_URL — shared from project
# PORT=3004
RESEND_API_KEY=re_...

# ── kitz-web (Next.js, port 3000) ───────────────────────────────────────────

# Build-time args (set in Railway build settings)
NEXT_PUBLIC_API_BASE=https://factory-api-production.up.railway.app
NEXT_PUBLIC_GATEWAY_URL=https://kitz-gateway-production.up.railway.app

# ── renewflo (Vite SPA + proxy, port 3000) ──────────────────────────────────

# Build-time arg
VITE_API_BASE=/api

# Runtime — proxy target (use Railway private networking)
GATEWAY_URL=http://kitz-gateway.railway.internal:8787
