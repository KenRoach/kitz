# RenewFlow Environment Configuration
# Copy to .env and fill in values

# Anthropic API (for AI Chat feature)
VITE_ANTHROPIC_API_KEY=

# API Base URL (Kitz Gateway)
VITE_API_BASE=http://localhost:8787/v0.1

# Feature Flags
VITE_FEATURE_AI_CHAT=true
VITE_FEATURE_REWARDS=true
VITE_FEATURE_PO_MANAGEMENT=true
