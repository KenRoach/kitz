{
  "$schema": "https://railway.com/railway.schema.json",
  "services": {
    "kitz-gateway": {
      "source": { "repo": ".", "branch": "main" },
      "build": { "dockerfilePath": "Dockerfile" },
      "deploy": {
        "healthcheckPath": "/health",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      },
      "networking": { "internalPort": 8787 },
      "variables": {
        "PORT": "8787",
        "HOST": "0.0.0.0",
        "AUTH_ENABLED": "true",
        "NODE_ENV": "production"
      }
    },
    "factory-api": {
      "source": { "repo": ".", "branch": "main" },
      "build": {
        "dockerfilePath": "docker/Dockerfile.service",
        "buildArgs": { "SERVICE": "factory-api" }
      },
      "deploy": { "healthcheckPath": "/health" },
      "networking": { "internalPort": 3000 },
      "variables": { "PORT": "3000" }
    },
    "agent-runtime": {
      "source": { "repo": ".", "branch": "main" },
      "build": {
        "dockerfilePath": "docker/Dockerfile.service",
        "buildArgs": { "SERVICE": "agent-runtime" }
      },
      "deploy": { "healthcheckPath": "/health" },
      "networking": { "internalPort": 3001 },
      "variables": { "PORT": "3001" }
    },
    "contact-engine": {
      "source": { "repo": ".", "branch": "main" },
      "build": {
        "dockerfilePath": "docker/Dockerfile.service",
        "buildArgs": { "SERVICE": "contact-engine" }
      },
      "deploy": { "healthcheckPath": "/health" },
      "networking": { "internalPort": 3003 },
      "variables": { "PORT": "3003" }
    },
    "pipeline-runner": {
      "source": { "repo": ".", "branch": "main" },
      "build": {
        "dockerfilePath": "docker/Dockerfile.service",
        "buildArgs": { "SERVICE": "pipeline-runner" }
      },
      "deploy": { "healthcheckPath": "/health" },
      "networking": { "internalPort": 3002 },
      "variables": { "PORT": "3002" }
    },
    "channel-router": {
      "source": { "repo": ".", "branch": "main" },
      "build": {
        "dockerfilePath": "docker/Dockerfile.service",
        "buildArgs": { "SERVICE": "channel-router" }
      },
      "deploy": { "healthcheckPath": "/health" },
      "networking": { "internalPort": 3004 },
      "variables": { "PORT": "3004" }
    },
    "kitz-web": {
      "source": { "repo": ".", "branch": "main" },
      "build": {
        "dockerfilePath": "docker/Dockerfile.kitz-next",
        "buildArgs": {
          "NEXT_PUBLIC_API_BASE": "${{factory-api.RAILWAY_PUBLIC_DOMAIN_URL}}",
          "NEXT_PUBLIC_GATEWAY_URL": "${{kitz-gateway.RAILWAY_PUBLIC_DOMAIN_URL}}"
        }
      },
      "deploy": { "healthcheckPath": "/" },
      "networking": { "internalPort": 3000 },
      "variables": { "PORT": "3000" }
    },
    "renewflow": {
      "source": { "repo": ".", "branch": "main" },
      "build": {
        "dockerfilePath": "docker/Dockerfile.renewflow"
      },
      "deploy": { "healthcheckPath": "/" },
      "networking": { "internalPort": 3000 },
      "variables": {
        "PORT": "3000",
        "GATEWAY_URL": "${{kitz-gateway.RAILWAY_PRIVATE_DOMAIN}}:8787"
      }
    }
  }
}
