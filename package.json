{
  "name": "kitz-factory",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "db:generate": "pnpm --filter @kitz/core exec prisma generate",
    "db:push": "pnpm --filter @kitz/core exec prisma db push",
    "db:migrate": "pnpm --filter @kitz/core exec prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter @kitz/core exec prisma migrate deploy",
    "happy-path": "node scripts/happy-path-api.mjs",
    "seed:skills": "node scripts/seed-kitz-skills.mjs",
    "production-verify": "bash scripts/production-verify.sh"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  }
}
