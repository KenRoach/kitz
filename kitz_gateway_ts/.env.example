# Kitz Gateway Configuration
PORT=8787
HOST=0.0.0.0

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Authentication
AUTH_ENABLED=true

# Anthropic (for AI quoting + chat)
ANTHROPIC_API_KEY=sk-ant-...

# SMTP (for warranty alerts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=alerts@renewflow.io

# Static frontend (path to renewflo/dist)
STATIC_DIR=
