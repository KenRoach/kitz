# Kitz Gateway Configuration
PORT=8787
HOST=0.0.0.0

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Authentication
AUTH_ENABLED=true

# Anthropic (for AI quoting + chat)
ANTHROPIC_API_KEY=sk-ant-...

# Email — Resend (https://resend.com — free 100 emails/day)
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
SMTP_FROM=RenewFlow <noreply@renewflow.io>

# Or use any SMTP provider instead:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USER=your-user
# SMTP_PASS=your-pass

# App URL (used in password reset links)
APP_URL=https://renewflow.io

# Static frontend (path to renewflo/dist)
STATIC_DIR=
